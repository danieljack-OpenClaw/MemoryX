name: memoryx
description: MemoryX - AI Agent 长期记忆系统，提供语义搜索和 Token 压缩，支持本地+云端双存储
version: 1.0.2
author: MemoryX Team
homepage: https://github.com/danieljack-OpenClaw/MemoryX

trigger:
  - memoryx
  - 记住
  - 记忆
  - 保存
  - 搜索
  - 回忆

capabilities:
  memory:
    description: 长期记忆存储与检索
    actions:
      - add
      - search
      - delete
      - context
      - list
  recall:
    description: 语义搜索记忆
    trigger: ["搜索", "回忆", "查找"]
  remember:
    description: 记住内容
    trigger: ["记住", "记住"]

config:
  storage_path:
    type: string
    default: ~/.memoryx
    description: 记忆存储路径
  max_context_tokens:
    type: number
    default: 500
    description: 上下文最大 Token 数
  auto_backup:
    type: boolean
    default: true
    description: 自动备份开关

examples:
  - "记住我喜欢蓝色"
  - "搜索颜色偏好"
  - "回忆今天的工作"
  - "获取记忆上下文"
  - "打开 Dashboard"
